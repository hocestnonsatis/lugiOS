{
  "name": "lugios",
  "version": "0.1.0",
  "description": "LugiOS — desktop runtime and marketplace for sandboxed web mini-apps (Tauri v2 + SvelteKit)",
  "type": "module",
  "scripts": {
    "build:sdk": "npm --prefix ./sdk run build",
    "postinstall": "npm --prefix ./sdk install",
    "dev": "vite dev",
    "build": "npm run build:sdk && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "icons": "node scripts/gen-branding-path-icons.mjs && tauri icon branding/lugios-app-icon.svg -o src-tauri/icons --ios-color \"#0c0f14\" && node scripts/sync-web-favicon.mjs",
    "package:demo-hello": "node scripts/package-demo-hello.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.27",
    "opentype.js": "^1.3.4",
    "postcss": "^8.5.8",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
