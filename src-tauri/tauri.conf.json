{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LugiOS",
  "version": "0.1.0",
  "identifier": "com.hocestnonsatis.lugios",
  "build": {
    "beforeDevCommand": "npm run build:sdk && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LugiOS",
        "width": 960,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/bridge.iife.js"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
