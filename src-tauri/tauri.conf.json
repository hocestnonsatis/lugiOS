{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LugiOS",
  "version": "0.1.0",
  "identifier": "com.hocestnonsatis.lugios",
  "build": {
    "beforeDevCommand": "npm run build:sdk && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LugiOS",
        "width": 960,
        "height": 700,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "resources": ["resources/bridge.iife.js"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4MjlFRDRCMUQ5NzA3NEIKUldSTEI1Y2RTKzBwNkJLbDZqenhGWlRrckZNdGIwWE1sS3FQYkhucUViZDVjZ3Z3VklQa1FHcTcK",
      "endpoints": [
        "https://github.com/hocestnonsatis/lugiOS/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
