{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main LugiOS host shell window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:webview:allow-create-webview-window",
    "dialog:default",
    "fs:default",
    "notification:default",
    "updater:default",
    "process:default",
    "sql:default",
    "allow-get-registry",
    "allow-refresh-registry",
    "allow-install-app",
    "allow-uninstall-app",
    "allow-list-installed",
    "allow-get-grant",
    "allow-launch-app",
    "allow-close-app",
    "allow-list-running-apps",
    "allow-storage-get",
    "allow-storage-set",
    "allow-storage-delete",
    "allow-lugos-fs-pick-read",
    "allow-lugos-fs-save-dialog",
    "allow-lugos-clipboard-read",
    "allow-lugos-clipboard-write",
    "allow-lugos-notification-send",
    "allow-lugos-audio-read-asset",
    "allow-lugos-fetch",
    "allow-preview-app-manifest",
    "allow-get-github-repo-stats",
    "allow-check-app-updates",
    "allow-upgrade-app",
    "allow-get-host-settings",
    "allow-set-host-registry-url"
  ]
}
